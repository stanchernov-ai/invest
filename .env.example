# Copy to .env and fill in values (never commit .env)

# Local Docker Postgres (see scripts/provision_local_postgres.ps1)
DATABASE_URL=postgresql://boardroom_app:local_dev_password@localhost:5432/boardroom

# Sandbox import maps to this user row (created on first import)
SANDBOX_USER_SLUG=local-sandbox
SANDBOX_USER_EMAIL=sandbox@local.dev
